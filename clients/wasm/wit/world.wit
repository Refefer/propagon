interface trajectories {
    use types.{error, scores-bulk};
    use datasets.{trajectories-dataset};

    /// Pooling granularity for behavior cloning: `per-state` carries the
    /// substring separator char.
    variant granularity {
        global,
        per-state(char),
    }

    /// Significance-test toggle for value comparison: `on` carries the
    /// permutation count.
    variant pairwise-tests {
        off,
        on(u32),
    }

    /// Outlier clipping for Monte-Carlo value: `percentile` carries the
    /// two-sided fraction.
    variant winsorize {
        off,
        percentile(f64),
    }

    record mc-value-params {
        gamma: option<f64>,
        visit: option<string>,
        aggregate: option<string>,
        winsorize: option<winsorize>,
        min-observations: option<u32>,
    }

    resource mc-value-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }

    fit-mc-value: func(params: mc-value-params, data: borrow<trajectories-dataset>) -> result<mc-value-model, error>;
    fit-warm-mc-value: func(params: mc-value-params, data: borrow<trajectories-dataset>, init: borrow<mc-value-model>) -> result<mc-value-model, error>;
    load-mc-value: func(state: string) -> result<mc-value-model, error>;

    /// `granularity`: "global" or per-state; `smoothing` is additive.
    record behavior-cloning-params {
        granularity: option<granularity>,
        smoothing: option<f64>,
    }
    resource behavior-cloning-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-behavior-cloning: func(params: behavior-cloning-params, data: borrow<trajectories-dataset>) -> result<behavior-cloning-model, error>;
    fit-warm-behavior-cloning: func(params: behavior-cloning-params, data: borrow<trajectories-dataset>, init: borrow<behavior-cloning-model>) -> result<behavior-cloning-model, error>;
    load-behavior-cloning: func(state: string) -> result<behavior-cloning-model, error>;

    /// `visit`: "first" | "every"; `method`: resampling scheme.
    record value-compare-params {
        gamma: option<f64>,
        visit: option<string>,
        replicates: option<u32>,
        method: option<string>,
        credible: option<f64>,
        pairwise: option<pairwise-tests>,
        min-observations: option<u32>,
        seed: option<u64>,
    }
    resource value-compare-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-value-compare: func(params: value-compare-params, data: borrow<trajectories-dataset>) -> result<value-compare-model, error>;
    fit-warm-value-compare: func(params: value-compare-params, data: borrow<trajectories-dataset>, init: borrow<value-compare-model>) -> result<value-compare-model, error>;
    load-value-compare: func(state: string) -> result<value-compare-model, error>;

    record td-value-params {
        alpha: option<f64>,
        gamma: option<f64>,
        passes: option<u32>,
        initial-value: option<f64>,
    }
    resource td-value-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
        update: func(data: borrow<trajectories-dataset>) -> result<_, error>;
    }
    init-td-value: func(params: td-value-params) -> td-value-model;
    fit-td-value: func(params: td-value-params, data: borrow<trajectories-dataset>) -> result<td-value-model, error>;
    load-td-value: func(state: string) -> result<td-value-model, error>;
}

interface betting {
    use types.{error, scores-bulk};
    use datasets.{odds-dataset, forecast-dataset, market-dataset};

    // --- §14.1 de-vigging (batch) ---
    record odds-devig-params {
        // "multiplicative" | "additive" | "power" | "shin"
        method: option<string>,
        // "error" | "clamp-renormalize"
        additive-clamp: option<string>,
        tolerance: option<f64>,
    }
    resource odds-devig-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
        n-events: func() -> u32;
        booksum: func(event: u32) -> option<f64>;
        insider-share: func(event: u32) -> option<f64>;
    }
    fit-odds-devig: func(params: odds-devig-params, data: borrow<odds-dataset>) -> result<odds-devig-model, error>;
    fit-warm-odds-devig: func(params: odds-devig-params, data: borrow<odds-dataset>, init: borrow<odds-devig-model>) -> result<odds-devig-model, error>;
    load-odds-devig: func(state: string) -> result<odds-devig-model, error>;

    // --- §14.2 opinion pools (batch) ---
    record opinion-pool-params {
        // "linear" | "logarithmic"
        kind: option<string>,
        extremize: option<f64>,
        // "error" | "skip" | "uniform"
        missing: option<string>,
        eps-floor: option<f64>,
    }
    resource opinion-pool-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-opinion-pool: func(params: opinion-pool-params, data: borrow<forecast-dataset>) -> result<opinion-pool-model, error>;
    fit-warm-opinion-pool: func(params: opinion-pool-params, data: borrow<forecast-dataset>, init: borrow<opinion-pool-model>) -> result<opinion-pool-model, error>;
    load-opinion-pool: func(state: string) -> result<opinion-pool-model, error>;

    // --- §14.3 LMSR prediction market (online) ---
    record lmsr-params {
        b: option<f64>,
    }
    resource lmsr-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
        update: func(data: borrow<market-dataset>) -> result<_, error>;
        price: func(outcome: string) -> option<f64>;
        cost: func() -> f64;
        trade-cost: func(outcome: string, shares: f64) -> option<f64>;
    }
    init-lmsr: func(params: lmsr-params) -> lmsr-model;
    fit-lmsr: func(params: lmsr-params, data: borrow<market-dataset>) -> result<lmsr-model, error>;
    load-lmsr: func(state: string) -> result<lmsr-model, error>;

    // --- §14.4 Kelly staking (free functions) ---
    kelly-fraction: func(p: f64, b: f64) -> result<f64, error>;
    fractional-kelly: func(p: f64, b: f64, lambda: f64) -> result<f64, error>;
    portfolio-kelly: func(opportunities: list<tuple<f64, f64>>) -> result<list<f64>, error>;

    // --- §14.5 diagnostics (free functions) ---
    record calibration-bin {
        lo: f64,
        hi: f64,
        mean-pred: f64,
        realized-freq: f64,
        count: u32,
    }
    brier-score: func(forecasts: list<f64>, outcomes: list<bool>) -> result<f64, error>;
    log-loss: func(forecasts: list<f64>, outcomes: list<bool>) -> result<f64, error>;
    closing-line-value: func(taken: f64, closing: f64) -> result<f64, error>;
    calibration-table: func(implied: list<f64>, outcomes: list<bool>, n-buckets: u32) -> result<list<calibration-bin>, error>;
}

interface functions {
    use types.{error};
    use datasets.{graph-dataset};

    /// Wilson score interval `(low, high)` for `successes`/`failures` at `z`.
    wilson-interval: func(successes: f64, failures: f64, z: f64) -> tuple<f64, f64>;

    /// Split a graph into connected components, dropping any with fewer than
    /// `min-size` nodes.
    extract-components: func(graph: borrow<graph-dataset>, min-size: u32) -> list<graph-dataset>;
}

world propagon {
    export types;
    export datasets;
    export games;
    export graph;
    export pairwise;
    export rewards;
    export matchups;
    export annotated;
    export rankings;
    export trajectories;
    export betting;
    export functions;
}
