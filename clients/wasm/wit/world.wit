}

interface matchups {
    use types.{error, scores-bulk};
    use datasets.{matchups-dataset};

    /// A Weng-Lin (μ, σ) rating.
    record rating {
        mu: f64,
        sigma: f64,
    }

    record weng-lin-params {
        mu: option<f64>,
        sigma: option<f64>,
        beta: option<f64>,
        kappa: option<f64>,
        epsilon: option<f64>,
        tau: option<f64>,
    }

    resource weng-lin-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
        update: func(data: borrow<matchups-dataset>) -> result<_, error>;
        /// Per-player (μ, σ) ratings (weng-lin-specific).
        ratings: func() -> list<tuple<string, rating>>;
    }

    init-weng-lin: func(params: weng-lin-params) -> weng-lin-model;
    fit-weng-lin: func(params: weng-lin-params, data: borrow<matchups-dataset>) -> result<weng-lin-model, error>;
    load-weng-lin: func(state: string) -> result<weng-lin-model, error>;
}

