    fit-sliding-window-ucb: func(params: sliding-window-ucb-params, data: borrow<rewards-dataset>) -> result<sliding-window-ucb-model, error>;
    load-sliding-window-ucb: func(state: string) -> result<sliding-window-ucb-model, error>;

    record lin-ucb-params {
