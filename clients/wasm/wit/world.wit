interface rewards {
    use types.{error, scores-bulk};
    use datasets.{rewards-dataset, contextual-rewards-dataset};

    /// Arm-selection policy for the multi-armed bandit.
    variant bandit-policy {
        greedy,
        epsilon-greedy(f64),
        ucb1(f64),
        thompson-beta(tuple<f64, f64>),
        thompson-gaussian(tuple<f64, f64>),
        kl-ucb(f64),
        exp3(f64),
    }

    record bandit-params {
        policy: option<bandit-policy>,
        seed: option<u64>,
    }

    resource bandit-model {
        algorithm: func() -> string;
