        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
        update: func(data: borrow<rewards-dataset>) -> result<_, error>;
    }

    init-bandit: func(params: bandit-params) -> bandit-model;
    fit-bandit: func(params: bandit-params, data: borrow<rewards-dataset>) -> result<bandit-model, error>;
    load-bandit: func(state: string) -> result<bandit-model, error>;

