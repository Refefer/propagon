// Propagon WASM Component-Model interface.
//
// One artifact, many hosts: TypeScript consumes it via jco; other languages
// (Rust/Python/Go) via wasmtime + their bindgen. Mirrors the Python client's
// surface (clients/python). Datasets and fitted models are resources; algorithm
// parameters are by-value records with `option` fields (omit a field to take the
// core's default). Everything fallible returns `result<_, error>`.

package propagon:core;

interface types {
    /// Mirrors `propagon::Error` (crates/propagon/src/error.rs).
    variant error {
        invalid-input(string),
        empty-dataset,
        numeric(string),
        state(string),
        algorithm-mismatch(mismatch),
        param-mismatch(string),
        version(version-mismatch),
        parse(parse-error),
        io(string),
        json(string),
    }
    record mismatch {
        expected: string,
        found: string,
    }
    record version-mismatch {
        found: u32,
        supported: u32,
    }
    record parse-error {
        line: u64,
        msg: string,
    }

    /// Outcome of one game from side 1's perspective (margins are positive).
    variant game-outcome {
        side1-win(f64),
        side2-win(f64),
        tie,
    }

    /// Bulk score export: `ids[i]` is the entity for `scores[i]`. jco lowers
    /// `list<f64>` to a Float64Array, so large models cross the boundary without
    /// materializing a per-entity object graph.
    record scores-bulk {
        ids: list<string>,
        scores: list<f64>,
    }

    /// Refinement-pass budget for Kemeny and Mallows (shared).
    variant kemeny-passes {
        auto,
        fixed(u32),
    }
}

interface datasets {
    use types.{error, game-outcome};

    /// Win/loss pairs: `winner` beat `loser`.
    resource pairwise-dataset {
        constructor();
        push: func(winner: string, loser: string, weight: f64) -> result<_, error>;
        new-period: func();
        n-entities: func() -> u32;
        n-periods: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// Team-vs-team game results with margins.
    resource games-dataset {
        constructor();
        push-pair: func(winner: string, loser: string, weight: f64) -> result<_, error>;
        push-game: func(side1: list<string>, side2: list<string>, outcome: game-outcome, weight: f64) -> result<_, error>;
        new-period: func();
        n-entities: func() -> u32;
        n-periods: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// A directed, weighted endorsement graph (`src` endorses `dst`).
    resource graph-dataset {
        constructor();
        push: func(src: string, dst: string, weight: f64) -> result<_, error>;
        n-nodes: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// An `(arm, reward)` event log for multi-armed bandits.
    resource rewards-dataset {
        constructor();
        push: func(arm: string, reward: f64) -> result<_, error>;
        n-arms: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// An `(arm, reward, context)` event log for contextual bandits.
    resource contextual-rewards-dataset {
        constructor();
        push: func(arm: string, reward: f64, x: list<f64>) -> result<_, error>;
        n-arms: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// Multi-team match results with ranks (OpenSkill/Weng-Lin shape).
    resource matchups-dataset {
        constructor();
        push-match: func(teams: list<list<string>>, ranks: list<u32>) -> result<_, error>;
        n-entities: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// Annotator-tagged pairwise votes (the crowd shape).
    resource annotated-pairs-dataset {
        constructor();
        push: func(annotator: string, winner: string, loser: string, weight: f64) -> result<_, error>;
        n-entities: func() -> u32;
        n-annotators: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// Best-first ballots (the rank-aggregation shape).
    resource rankings-dataset {
        constructor();
        push-ranking: func(ranking: list<string>) -> result<_, error>;
        n-entities: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// State/reward episodes (the trajectory / value-estimation shape).
    resource trajectories-dataset {
        constructor();
        push-step: func(state: string, reward: f64) -> result<_, error>;
        end-episode: func();
        n-entities: func() -> u32;
        n-episodes: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// Posted decimal odds grouped by events (§14.1 de-vigging).
    resource odds-dataset {
        constructor();
        push-event: func(outcomes: list<tuple<string, f64>>) -> result<_, error>;
        n-entities: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// Several sources' probability forecasts over a common outcome space
    /// (§14.2 opinion pools).
    resource forecast-dataset {
        constructor();
        push-source: func(name: string, weight: f64, forecast: list<tuple<string, f64>>) -> result<_, error>;
        n-outcomes: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }

    /// A prediction-market trade stream (§14.3 LMSR).
    resource market-dataset {
        constructor();
        push-trade: func(outcome: string, shares: f64) -> result<_, error>;
        declare-outcome: func(outcome: string);
        n-entities: func() -> u32;
        len: func() -> u32;
        is-empty: func() -> bool;
    }
}

interface games {
    use types.{error, scores-bulk};
    use datasets.{games-dataset};

    record elo-params {
        k: option<f64>,
        initial-rating: option<f64>,
        scale: option<f64>,
    }

    resource elo-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
        update: func(data: borrow<games-dataset>) -> result<_, error>;
    }

    init-elo: func(params: elo-params) -> elo-model;
    fit-elo: func(params: elo-params, data: borrow<games-dataset>) -> result<elo-model, error>;
    load-elo: func(state: string) -> result<elo-model, error>;

    /// One entity's Glicko-2 state on the display (Elo-like) scale.
    record player-state {
        r: f64,
        rd: f64,
        sigma: f64,
    }

    record glicko2-params {
        tau: option<f64>,
        rating: option<f64>,
        rd: option<f64>,
        sigma: option<f64>,
    }

    resource glicko2-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
        update: func(data: borrow<games-dataset>) -> result<_, error>;
        /// Per-entity rating states (glicko2-specific).
        players: func() -> list<tuple<string, player-state>>;
    }

    init-glicko2: func(params: glicko2-params) -> glicko2-model;
    fit-glicko2: func(params: glicko2-params, data: borrow<games-dataset>) -> result<glicko2-model, error>;
    load-glicko2: func(state: string) -> result<glicko2-model, error>;

    record mov-elo-params {
        k: option<f64>,
        initial-rating: option<f64>,
        scale: option<f64>,
        mov-exponent: option<f64>,
    }
    resource mov-elo-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
        update: func(data: borrow<games-dataset>) -> result<_, error>;
    }
    init-mov-elo: func(params: mov-elo-params) -> mov-elo-model;
    fit-mov-elo: func(params: mov-elo-params, data: borrow<games-dataset>) -> result<mov-elo-model, error>;
    load-mov-elo: func(state: string) -> result<mov-elo-model, error>;

    record m-elo-params {
        k: option<u32>,
        lr-rating: option<f64>,
        lr-vector: option<f64>,
        initial-rating: option<f64>,
        init-scale: option<f64>,
        seed: option<u64>,
    }
    resource m-elo-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
        update: func(data: borrow<games-dataset>) -> result<_, error>;
    }
    init-m-elo: func(params: m-elo-params) -> m-elo-model;
    fit-m-elo: func(params: m-elo-params, data: borrow<games-dataset>) -> result<m-elo-model, error>;
    load-m-elo: func(state: string) -> result<m-elo-model, error>;

    /// `ties`: "none" | "davidson" | "rao-kupper"; `home`: "none" | "estimate".
    record generalized-bt-params {
        ties: option<string>,
        home: option<string>,
        iterations: option<u32>,
        tolerance: option<f64>,
    }
    resource generalized-bt-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-generalized-bt: func(params: generalized-bt-params, data: borrow<games-dataset>) -> result<generalized-bt-model, error>;
    fit-warm-generalized-bt: func(params: generalized-bt-params, data: borrow<games-dataset>, init: borrow<generalized-bt-model>) -> result<generalized-bt-model, error>;
    load-generalized-bt: func(state: string) -> result<generalized-bt-model, error>;

    /// `aggregate`: "additive" | "product"; `ties`: "error" | "discard" | "half-win".
    record team-bradley-terry-params {
        aggregate: option<string>,
        iterations: option<u32>,
        tolerance: option<f64>,
        ties: option<string>,
    }
    resource team-bradley-terry-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-team-bradley-terry: func(params: team-bradley-terry-params, data: borrow<games-dataset>) -> result<team-bradley-terry-model, error>;
    fit-warm-team-bradley-terry: func(params: team-bradley-terry-params, data: borrow<games-dataset>, init: borrow<team-bradley-terry-model>) -> result<team-bradley-terry-model, error>;
    load-team-bradley-terry: func(state: string) -> result<team-bradley-terry-model, error>;
}

interface graph {
    use types.{error, scores-bulk};
    use datasets.{graph-dataset};

    enum sink {
        reverse,
        all,
        uniform,
        none,
    }

    variant teleport {
        uniform,
        seeds(list<tuple<string, f64>>),
    }

    /// Source-set budget for harmonic centrality: `sample` carries `(count, seed)`.
    variant source-budget {
        all,
        sample(tuple<u32, u64>),
    }

    record page-rank-params {
        damping: option<f64>,
        iterations: option<u32>,
        sink: option<sink>,
        teleport: option<teleport>,
    }

    resource page-rank-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }

    fit-page-rank: func(params: page-rank-params, data: borrow<graph-dataset>) -> result<page-rank-model, error>;
    fit-warm-page-rank: func(params: page-rank-params, data: borrow<graph-dataset>, init: borrow<page-rank-model>) -> result<page-rank-model, error>;
    load-page-rank: func(state: string) -> result<page-rank-model, error>;

    record hits-params {
        iterations: option<u32>,
        tolerance: option<f64>,
    }

    resource hits-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }

    fit-hits: func(params: hits-params, data: borrow<graph-dataset>) -> result<hits-model, error>;
    fit-warm-hits: func(params: hits-params, data: borrow<graph-dataset>, init: borrow<hits-model>) -> result<hits-model, error>;
    load-hits: func(state: string) -> result<hits-model, error>;

    record bi-rank-params {
        iterations: option<u32>,
        alpha: option<f64>,
        beta: option<f64>,
        seed: option<u64>,
    }
    resource bi-rank-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-bi-rank: func(params: bi-rank-params, data: borrow<graph-dataset>) -> result<bi-rank-model, error>;
    fit-warm-bi-rank: func(params: bi-rank-params, data: borrow<graph-dataset>, init: borrow<bi-rank-model>) -> result<bi-rank-model, error>;
    load-bi-rank: func(state: string) -> result<bi-rank-model, error>;

    /// `direction`: "in" | "out" | "total".
    record degree-params {
        direction: option<string>,
    }
    resource degree-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-degree: func(params: degree-params, data: borrow<graph-dataset>) -> result<degree-model, error>;
    fit-warm-degree: func(params: degree-params, data: borrow<graph-dataset>, init: borrow<degree-model>) -> result<degree-model, error>;
    load-degree: func(state: string) -> result<degree-model, error>;

    /// `direction`: "in" | "out" | "total"; `cost`: "unit" | "weight".
    record harmonic-params {
        direction: option<string>,
        cost: option<string>,
        sources: option<source-budget>,
    }
    resource harmonic-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-harmonic: func(params: harmonic-params, data: borrow<graph-dataset>) -> result<harmonic-model, error>;
    fit-warm-harmonic: func(params: harmonic-params, data: borrow<graph-dataset>, init: borrow<harmonic-model>) -> result<harmonic-model, error>;
    load-harmonic: func(state: string) -> result<harmonic-model, error>;

    record katz-params {
        alpha: option<f64>,
        iterations: option<u32>,
        tolerance: option<f64>,
    }
    resource katz-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-katz: func(params: katz-params, data: borrow<graph-dataset>) -> result<katz-model, error>;
    fit-warm-katz: func(params: katz-params, data: borrow<graph-dataset>, init: borrow<katz-model>) -> result<katz-model, error>;
    load-katz: func(state: string) -> result<katz-model, error>;

    resource k-core-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-k-core: func(data: borrow<graph-dataset>) -> result<k-core-model, error>;
    load-k-core: func(state: string) -> result<k-core-model, error>;

    record leader-rank-params {
        iterations: option<u32>,
        tolerance: option<f64>,
    }
    resource leader-rank-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-leader-rank: func(params: leader-rank-params, data: borrow<graph-dataset>) -> result<leader-rank-model, error>;
    fit-warm-leader-rank: func(params: leader-rank-params, data: borrow<graph-dataset>, init: borrow<leader-rank-model>) -> result<leader-rank-model, error>;
    load-leader-rank: func(state: string) -> result<leader-rank-model, error>;
}

interface pairwise {
    use types.{error, scores-bulk, kemeny-passes};
    use datasets.{pairwise-dataset};

    /// Comparison policy for the dueling bandit.
    variant dueling-policy {
        rucb(f64),
        double-thompson(f64),
    }

    record bradley-terry-mm-params {
        iterations: option<u32>,
        tolerance: option<f64>,
        min-graph-size: option<u32>,
        remove-total-losers: option<bool>,
        create-fake-games: option<f64>,
        random-subgraph-links: option<u32>,
        random-subgraph-weight: option<f64>,
        seed: option<u64>,
    }

    resource bradley-terry-mm-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }

    fit-bradley-terry-mm: func(params: bradley-terry-mm-params, data: borrow<pairwise-dataset>) -> result<bradley-terry-mm-model, error>;
    fit-warm-bradley-terry-mm: func(params: bradley-terry-mm-params, data: borrow<pairwise-dataset>, init: borrow<bradley-terry-mm-model>) -> result<bradley-terry-mm-model, error>;
    load-bradley-terry-mm: func(state: string) -> result<bradley-terry-mm-model, error>;

    resource borda-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }

    fit-borda: func(data: borrow<pairwise-dataset>) -> result<borda-model, error>;
    load-borda: func(state: string) -> result<borda-model, error>;

    record bradley-terry-lr-params {
        passes: option<u32>,
        alpha: option<f64>,
        decay: option<f64>,
        thrifty: option<bool>,
    }
    resource bradley-terry-lr-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-bradley-terry-lr: func(params: bradley-terry-lr-params, data: borrow<pairwise-dataset>) -> result<bradley-terry-lr-model, error>;
    fit-warm-bradley-terry-lr: func(params: bradley-terry-lr-params, data: borrow<pairwise-dataset>, init: borrow<bradley-terry-lr-model>) -> result<bradley-terry-lr-model, error>;
    load-bradley-terry-lr: func(state: string) -> result<bradley-terry-lr-model, error>;

    record bayesian-bradley-terry-params {
        shape: option<f64>,
        rate: option<f64>,
        samples: option<u32>,
        burn-in: option<u32>,
        credible: option<f64>,
        seed: option<u64>,
    }
    resource bayesian-bradley-terry-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-bayesian-bradley-terry: func(params: bayesian-bradley-terry-params, data: borrow<pairwise-dataset>) -> result<bayesian-bradley-terry-model, error>;
    fit-warm-bayesian-bradley-terry: func(params: bayesian-bradley-terry-params, data: borrow<pairwise-dataset>, init: borrow<bayesian-bradley-terry-model>) -> result<bayesian-bradley-terry-model, error>;
    load-bayesian-bradley-terry: func(state: string) -> result<bayesian-bradley-terry-model, error>;

    record colley-params {
        iterations: option<u32>,
        tolerance: option<f64>,
    }
    resource colley-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-colley: func(params: colley-params, data: borrow<pairwise-dataset>) -> result<colley-model, error>;
    fit-warm-colley: func(params: colley-params, data: borrow<pairwise-dataset>, init: borrow<colley-model>) -> result<colley-model, error>;
    load-colley: func(state: string) -> result<colley-model, error>;

    record massey-params {
        iterations: option<u32>,
        tolerance: option<f64>,
    }
    resource massey-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
    fit-massey: func(params: massey-params, data: borrow<pairwise-dataset>) -> result<massey-model, error>;
    fit-warm-massey: func(params: massey-params, data: borrow<pairwise-dataset>, init: borrow<massey-model>) -> result<massey-model, error>;
    load-massey: func(state: string) -> result<massey-model, error>;

    record keener-params {
        skew: option<bool>,
        normalize-games: option<bool>,
        iterations: option<u32>,
        tolerance: option<f64>,
    }
    resource keener-model {
        algorithm: func() -> string;
        sorted-scores: func() -> list<tuple<string, f64>>;
        score: func(name: string) -> option<f64>;
        top: func(k: u32) -> list<tuple<string, f64>>;
        scores-bulk: func() -> scores-bulk;
        save-state: func() -> result<string, error>;
    }
